{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "mocha", "@wdio/globals/types", "expect-webdriverio"]
  },
  "include": ["wdio.conf.ts", "specs/**/*.ts"]
}
