{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "push": true,
    "requireBranch": "main"
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": "node scripts/sync-versions.mjs ${version} && git add packages/desktop/src-tauri/tauri.conf.json packages/backend/services/version.ts"
  }
}
